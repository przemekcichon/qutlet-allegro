<?xml version="1.0" encoding="UTF-8"?>
<!--
    Harness testów jednostkowych qutlet-allegro (P-6.0, warunek wejścia FAZY 6).

    Testy są BEZ SIECI i BEZ WordPressa: pokrywają czyste klasy domenowe (dziś
    SandboxSeed\IdMap), które nie dotykają runtime WP. Bootstrap to sam autoloader
    Composera — żadnego ładowania rdzenia WP. Gdy późniejszy punkt wprowadzi test
    wymagający WP, dostanie osobny testsuite z własnym bootstrapem.
-->
<phpunit xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
         xsi:noNamespaceSchemaLocation="vendor/phpunit/phpunit/phpunit.xsd"
         bootstrap="vendor/autoload.php"
         colors="true"
         failOnWarning="true"
         failOnRisky="true"
         beStrictAboutTestsThatDoNotTestAnything="true"
         beStrictAboutOutputDuringTests="true"
         cacheResult="false">
    <testsuites>
        <testsuite name="unit">
            <directory>tests</directory>
        </testsuite>
    </testsuites>
</phpunit>
