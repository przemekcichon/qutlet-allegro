{
    "name": "qutlet/qutlet-allegro",
    "description": "Qutlet Allegro — synchronizacja danych qutlet ↔ Allegro.",
    "type": "wordpress-plugin",
    "license": "proprietary",
    "require": {
        "php": ">=7.4"
    },
    "require-dev": {
        "php-stubs/wp-cli-stubs": "^2.12",
        "phpstan/phpstan": "^2.0",
        "phpunit/phpunit": "^9.6",
        "szepeviktor/phpstan-wordpress": "^2.0"
    },
    "autoload": {
        "psr-4": {
            "Qutlet\\Allegro\\": "src/"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "Qutlet\\Allegro\\Tests\\": "tests/"
        }
    },
    "config": {
        "sort-packages": true
    },
    "scripts": {
        "phpstan": "phpstan analyse",
        "test": "phpunit"
    }
}
